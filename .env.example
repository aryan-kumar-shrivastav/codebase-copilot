# Copy to .env and fill in.

DATABASE_URL=postgresql+psycopg2://copilot:copilot@localhost:5432/copilot

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

LLM_MODEL=claude-sonnet-4-6
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

SANDBOX_REPO_ROOT=/tmp/copilot_repos
TRACE_LOG_PATH=/tmp/copilot_traces
